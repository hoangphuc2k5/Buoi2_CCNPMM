<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đặt lại mật khẩu</title>
    <style>
        .success { color: green; }
        .error   { color: red; }
    </style>
</head>
<body>
    <h2>Đặt lại mật khẩu</h2>

    <% if (message) { %>
        <p class="<%= success ? 'success' : 'error' %>"><%= message %></p>
    <% } %>

    <form action="/api/auth/reset-password" method="POST">
        <label>Email:</label><br>
        <input type="email" name="email" value="<%= email %>" required /><br><br>
        <label>Mã OTP:</label><br>
        <input type="text" name="otp" placeholder="Nhập mã OTP" required /><br><br>
        <label>Mật khẩu mới:</label><br>
        <input type="password" name="newPassword" placeholder="Nhập mật khẩu mới" required /><br><br>
        <button type="submit">Đặt lại mật khẩu</button>
    </form>
</body>
</html>