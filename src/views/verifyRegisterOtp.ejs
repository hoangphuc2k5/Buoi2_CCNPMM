<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kich hoat OTP register</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            max-width: 480px;
            margin: 40px auto;
            line-height: 1.5;
        }
        .success { color: green; }
        .error { color: red; }
        input {
            width: 100%;
            padding: 10px;
            box-sizing: border-box;
            margin: 6px 0 14px;
        }
        button {
            padding: 10px 16px;
            cursor: pointer;
        }
        a {
            display: inline-block;
            margin-top: 12px;
        }
    </style>
</head>
<body>
    <h2>Nhap OTP kich hoat tai khoan</h2>
    <p>Nhap email va ma OTP da duoc gui sau khi dang ky.</p>

    <p id="message"></p>

    <form id="verifyRegisterOtpForm">
        <label>Email:</label>
        <input type="email" name="email" placeholder="Nhap email" required />

        <label>Ma OTP:</label>
        <input type="text" name="otp" placeholder="Nhap ma OTP" required />

        <button type="submit">Kich hoat tai khoan</button>
    </form>

    <a href="/register">Quay lai trang register</a>

    <script>
        const form = document.getElementById('verifyRegisterOtpForm');
        const message = document.getElementById('message');

        form.addEventListener('submit', async (event) => {
            event.preventDefault();

            const payload = {
                email: form.email.value,
                otp: form.otp.value,
            };

            const response = await fetch('/api/auth/verify-register-otp', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify(payload),
            });

            const data = await response.json();
            message.textContent = data.message;
            message.className = data.success ? 'success' : 'error';
        });
    </script>
</body>
</html>
